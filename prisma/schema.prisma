generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String?  @unique
  cpf       String   @unique
  telefone  String
  perfil    Perfil
  ativo     Boolean  @default(true)
  criado_em DateTime @default(now())

  ocorrencias_criadas   Ocorrencia[]         @relation("OcorrenciaUsuario")
  ocorrencias_atendidas Ocorrencia[]         @relation("OcorrenciaBrigadista")
  dispositivos          Dispositivo[]
  usuario_ocorrencias   UsuarioOcorrencia[]

  @@map("usuario")
}

model Dispositivo {
  id         Int      @id @default(autoincrement())
  usuario_id Int
  uuid       String
  descricao  String?
  ativo      Boolean  @default(true)
  criado_em  DateTime @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id])

  @@map("dispositivo")
}

model Ocorrencia {
  id            Int           @id @default(autoincrement())
  usuario_id    Int
  brigadista_id Int?
  latitude      Float?
  longitude     Float?
  status        StatusOcorrencia @default(ABERTA)
  criado_em     DateTime      @default(now())
  finalizado_em DateTime?

  usuario    Usuario @relation("OcorrenciaUsuario", fields: [usuario_id], references: [id])
  brigadista Usuario? @relation("OcorrenciaBrigadista", fields: [brigadista_id], references: [id])

  usuario_ocorrencias UsuarioOcorrencia[]
  logs                LogOcorrencia[]

  @@map("ocorrencia")
}

model UsuarioOcorrencia {
  id           Int     @id @default(autoincrement())
  usuario_id   Int
  ocorrencia_id Int
  papel        Papel?

  usuario    Usuario    @relation(fields: [usuario_id], references: [id])
  ocorrencia Ocorrencia @relation(fields: [ocorrencia_id], references: [id])

  @@map("usuario_ocorrencia")
}

model LogOcorrencia {
  id            Int      @id @default(autoincrement())
  ocorrencia_id Int
  descricao     String
  criado_em     DateTime @default(now())

  ocorrencia Ocorrencia @relation(fields: [ocorrencia_id], references: [id])

  @@map("log_ocorrencia")
}

enum Perfil {
  CIVIL
  BRIGADA
  INTERNO
}

enum StatusOcorrencia {
  ABERTA
  EM_ATENDIMENTO
  FINALIZADA
}

enum Papel {
  BRIGADA
  INTERNO
}
